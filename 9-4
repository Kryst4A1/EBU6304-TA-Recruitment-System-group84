package service.impl;

import core.exception.BusinessException;
import core.fsm.ApplyState;
import core.fsm.ApplyStateMachine;
import dao.ApplyDAO;
import dao.JobDAO;
import dao.impl.ApplyDAOImpl;
import dao.impl.JobDAOImpl;
import model.Apply;
import model.Job;
import service.MOService;

import java.util.List;

public class MOServiceImpl implements MOService {
    private JobDAO jobDAO = new JobDAOImpl();
    private ApplyDAO applyDAO = new ApplyDAOImpl();

    @Override
    public List<Job> getJobsByMoId(Integer moId) {
        return jobDAO.findByMoId(moId);
    }

    @Override
    public boolean createJob(Job job) {
        // 参数校验
        if (job.getTitle() == null || job.getTitle().isEmpty()) {
            throw new BusinessException(400, "岗位名称不能为空");
        }
        if (job.getMoId() == null) {
            throw new BusinessException(400, "发布者ID不能为空");
        }

        // 默认状态为已发布
        if (job.getStatus() == null) {
            job.setStatus(1);
        }

        return jobDAO.save(job);
    }

    @Override
    public boolean updateJob(Job job) {
        // 校验岗位是否存在且属于当前MO
        Job existingJob = jobDAO.findById(job.getId());
        if (existingJob == null) {
            throw new BusinessException(400, "岗位不存在");
        }
        if (!existingJob.getMoId().equals(job.getMoId())) {
            throw new BusinessException(403, "无权限修改该岗位");
        }

        return jobDAO.update(job);
    }

    @Override
    public boolean deleteJob(Integer jobId, Integer moId) {
        // 校验岗位是否存在且属于当前MO
        Job existingJob = jobDAO.findById(jobId);
        if (existingJob == null) {
            throw new BusinessException(400, "岗位不存在");
        }
        if (!existingJob.getMoId().equals(moId)) {
            throw new BusinessException(403, "无权限删除该岗位");
        }

        return jobDAO.deleteById(jobId);
    }

    @Override
    public List<Apply> getAppliesByMoId(Integer moId) {
        return applyDAO.findByMoId(moId);
    }

    @Override
    public boolean reviewApply(Integer applyId, String status, Integer moId) {
        // 校验申请是否存在
        Apply apply = applyDAO.findById(applyId);
        if (apply == null) {
            throw new BusinessException(400, "申请不存在");
        }

        // 校验岗位是否属于当前MO
        Job job = jobDAO.findById(apply.getJobId());
        if (job == null || !job.getMoId().equals(moId)) {
            throw new BusinessException(403, "无权限审核该申请");
        }

        // 校验状态是否可以转移
        ApplyState currentState = ApplyState.valueOf(apply.getStatus());
        ApplyState targetState = ApplyState.valueOf(status);
        if (!ApplyStateMachine.canTransition(currentState, targetState)) {
            throw new BusinessException(400, "只能审核未处理的申请");
        }

        // 更新申请状态
        return applyDAO.updateStatus(applyId, status);
    }
}
