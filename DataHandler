import java.io.*;
import java.util.HashMap;
import java.util.List;
import java.util.Map;

/**
 * Data processing class: read/write jobs, applications, TA profiles
 */
public class DataHandler {

    // Load all available jobs
    public static List<String> loadAllJobs() {
        return Utils.readFileLines(Utils.DATA_FOLDER + "job_list.csv");
    }

    // Submit job application
    public static boolean submitApplication(String applicationData) {
        String filePath = Utils.DATA_FOLDER + "application_list.csv";
        File file = new File(filePath);

        try (BufferedWriter bw = new BufferedWriter(new FileWriter(file, true))) {
            // Write header if file is empty
            if (!file.exists() || file.length() == 0) {
                bw.write("JobID,StudentID,Name,Major,Phone,CV_Path,Apply_Time,Status");
                bw.newLine();
            }
            bw.write(applicationData);
            bw.newLine();
            System.out.println("[SUCCESS] Application submitted successfully!");
            return true;
        } catch (IOException e) {
            System.out.println("[ERROR] Failed to submit application: " + e.getMessage());
            return false;
        }
    }

    // Load all applications
    public static List<String> loadAllApplications() {
        return Utils.readFileLines(Utils.DATA_FOLDER + "application_list.csv");
    }

    // Load TA profile by student ID
    public static Map<String, String> loadTAProfile(String studentId) {
        String path = Utils.DATA_FOLDER + "ta_profile_" + studentId + ".json";
        List<String> lines = Utils.readFileLines(path);
        if (lines == null) return null;

        Map<String, String> profile = new HashMap<>();
        for (String line : lines) {
            line = line.trim();
            if (line.contains(":")) {
                String[] keyValue = line.split(":", 2);
                String key = keyValue[0].replace("\"", "").trim();
                String value = keyValue[1].replace("\"", "").replace(",", "").trim();
                profile.put(key, value);
            }
        }
        return profile;
    }

    // Save TA profile to JSON file
    public static boolean saveTAProfile(String studentId, String profileContent) {
        String path = Utils.DATA_FOLDER + "ta_profile_" + studentId + ".json";
        try (BufferedWriter bw = new BufferedWriter(new FileWriter(path))) {
            bw.write(profileContent);
            System.out.println("[SUCCESS] Profile saved successfully!");
            return true;
        } catch (IOException e) {
            System.out.println("[ERROR] Failed to save profile.");
            return false;
        }
    }

    // Publish new job to CSV
    public static boolean publishJob(String jobData) {
        String path = Utils.DATA_FOLDER + "job_list.csv";
        File file = new File(path);
        try (BufferedWriter bw = new BufferedWriter(new FileWriter(file, true))) {
            if (!file.exists() || file.length() == 0) {
                bw.write("JobID,CourseCode,Position,Hours,Requirements");
                bw.newLine();
            }
            bw.write(jobData);
            bw.newLine();
            System.out.println("[SUCCESS] Job published successfully!");
            return true;
        } catch (IOException e) {
            System.out.println("[ERROR] Failed to publish job.");
            return false;
        }
    }
}
