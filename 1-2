package core;

public class CharsetUtil {
    public static final String UTF8 = "UTF-8";
    public static final String GBK = "GBK";

    // 处理中文乱码和特殊字符
    public static String convertSpecialChar(String str) {
        if (str == null) return "";
        return str.replaceAll("\\s+", " ").replace("�", "").trim();
    }
}




