package core.fsm;

public enum ApplyState {
    PENDING("待审核"),
    ACCEPTED("已录取"),
    REJECTED("已拒绝"),
    CANCELED("已撤销");

    private final String description;

    ApplyState(String description) {
        this.description = description;
    }

    public String getDescription() {
        return description;
    }
}





