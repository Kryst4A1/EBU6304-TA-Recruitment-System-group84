package core.fsm;

import core.LogUtil;
import java.util.HashMap;
import java.util.HashSet;
import java.util.Map;
import java.util.Set;

public class ApplyStateMachine {
    private static final Map<ApplyState, Set<ApplyState>> TRANSITION_MAP = new HashMap<>();

    static {
        // 定义合法的状态转移
        TRANSITION_MAP.put(ApplyState.PENDING, new HashSet<>() {{
            add(ApplyState.ACCEPTED);
            add(ApplyState.REJECTED);
            add(ApplyState.CANCELED);
        }});

        // 已录取、已拒绝、已撤销的申请不能再转移状态
        TRANSITION_MAP.put(ApplyState.ACCEPTED, new HashSet<>());
        TRANSITION_MAP.put(ApplyState.REJECTED, new HashSet<>());
        TRANSITION_MAP.put(ApplyState.CANCELED, new HashSet<>());
    }

    public static boolean canTransition(ApplyState currentState, ApplyState targetState) {
        Set<ApplyState> allowedTransitions = TRANSITION_MAP.get(currentState);
        boolean allowed = allowedTransitions != null && allowedTransitions.contains(targetState);
        if (!allowed) {
            LogUtil.warn("非法状态转移：" + currentState + " -> " + targetState);
        }
        return allowed;
    }
}
