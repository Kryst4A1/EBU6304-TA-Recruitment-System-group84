public class RecruitmentUI extends JFrame {
    private JPanel contentPane;
    private CardLayout mainCardLayout;
    private JPanel functionPanel;

    // UI 输出组件升级：支持文本和表格的双重展示
    private JTextArea taDisplay, moDisplay;
    private JTable taTable, moTable;
    private DefaultTableModel taTableModel, moTableModel;

    // 全局统一字体配置
    private final Font TITLE_FONT = new Font("SansSerif", Font.BOLD, 18);
    private final Font NORMAL_FONT = new Font("SansSerif", Font.PLAIN, 14);

    public RecruitmentUI() {
        setTitle("BUPT International School TA Recruitment System");
        setDefaultCloseOperation(JFrame.EXIT_ON_CLOSE);
        setSize(950, 650);
        setLocationRelativeTo(null); // 窗口居中

        contentPane = new JPanel(new BorderLayout(15, 15));
        contentPane.setBorder(new EmptyBorder(15, 15, 15, 15));
        setContentPane(contentPane);

        // 1. 顶部角色选择栏
        JPanel rolePanel = new JPanel(new FlowLayout(FlowLayout.CENTER, 30, 10));
        rolePanel.setBorder(BorderFactory.createMatteBorder(0, 0, 2, 0, Color.LIGHT_GRAY));
        JButton btnTA = new JButton("Switch to TA Role");
        JButton btnMO = new JButton("Switch to MO Role");
        btnTA.setFont(TITLE_FONT);
        btnMO.setFont(TITLE_FONT);
        rolePanel.add(btnTA);
        rolePanel.add(btnMO);
        contentPane.add(rolePanel, BorderLayout.NORTH);

        // 2. 主功能区
        mainCardLayout = new CardLayout();
        functionPanel = new JPanel(mainCardLayout);
        functionPanel.add(createTAModule(), "TA_MODULE");
        functionPanel.add(createMOModule(), "MO_MODULE");
        contentPane.add(functionPanel, BorderLayout.CENTER);

        // 3. 角色切换事件
        btnTA.addActionListener(e -> mainCardLayout.show(functionPanel, "TA_MODULE"));
        btnMO.addActionListener(e -> mainCardLayout.show(functionPanel, "MO_MODULE"));

        // 4. 初始化系统
        Utils.initSystem();
        mainCardLayout.show(functionPanel, "TA_MODULE");
    }

    // ===================== TA模块 =====================
    private JPanel createTAModule() {
        JPanel taModule = new JPanel(new BorderLayout(15, 15));

        // 顶部按钮区
        JPanel taBtnPanel = new JPanel(new GridLayout(1, 5, 10, 10));
        JButton btnCreateProfile = new JButton("1. Profile");
        JButton btnUploadCV = new JButton("2. Upload CV");
        JButton btnViewJobs = new JButton("3. View Jobs");
        JButton btnApplyJob = new JButton("4. Apply");
        JButton btnCheckStatus = new JButton("5. Status");

        JButton[] buttons = {btnCreateProfile, btnUploadCV, btnViewJobs, btnApplyJob, btnCheckStatus};
        for (JButton btn : buttons) {
            btn.setFont(NORMAL_FONT);
            taBtnPanel.add(btn);
        }
        taModule.add(taBtnPanel, BorderLayout.NORTH);

        // 中间输入区
        CardLayout taInputCard = new CardLayout();
        JPanel taInputPanel = new JPanel(taInputCard);
        taInputPanel.add(new JPanel(), "EMPTY");

        // [输入面板 1] Profile
        JPanel profilePanel = new JPanel(new GridLayout(6, 2, 10, 10));
        profilePanel.setBorder(BorderFactory.createTitledBorder(null, "Create / Update Profile", TitledBorder.DEFAULT_JUSTIFICATION, TitledBorder.DEFAULT_POSITION, TITLE_FONT));
        JTextField txtStudentId = new JTextField(); JTextField txtName = new JTextField();
        JTextField txtMajor = new JTextField(); JTextField txtPhone = new JTextField(); JTextField txtCVPath = new JTextField();
        profilePanel.add(new JLabel("Student ID:")); profilePanel.add(txtStudentId);
        profilePanel.add(new JLabel("Full Name:")); profilePanel.add(txtName);
        profilePanel.add(new JLabel("Major:")); profilePanel.add(txtMajor);
        profilePanel.add(new JLabel("Phone:")); profilePanel.add(txtPhone);
        profilePanel.add(new JLabel("CV Path:")); profilePanel.add(txtCVPath);
        JButton btnSubmitProfile = new JButton("Save Profile");
        profilePanel.add(new JLabel()); profilePanel.add(btnSubmitProfile);
        taInputPanel.add(profilePanel, "PROFILE");

        // [输入面板 2] Upload CV
        JPanel cvPanel = new JPanel(new GridLayout(2, 2, 10, 10));
        cvPanel.setBorder(BorderFactory.createTitledBorder(null, "Upload CV File", TitledBorder.DEFAULT_JUSTIFICATION, TitledBorder.DEFAULT_POSITION, TITLE_FONT));
        JTextField txtCVUploadPath = new JTextField();
        cvPanel.add(new JLabel("CV File Path:")); cvPanel.add(txtCVUploadPath);
        JButton btnSubmitCV = new JButton("Upload");
        cvPanel.add(new JLabel()); cvPanel.add(btnSubmitCV);
        taInputPanel.add(cvPanel, "CV_UPLOAD");

        // [输入面板 3] Apply Job
        JPanel applyPanel = new JPanel(new GridLayout(3, 2, 10, 10));
        applyPanel.setBorder(BorderFactory.createTitledBorder(null, "Apply for a Job", TitledBorder.DEFAULT_JUSTIFICATION, TitledBorder.DEFAULT_POSITION, TITLE_FONT));
        JTextField txtApplyStudentId = new JTextField(); JTextField txtApplyJobId = new JTextField();
        applyPanel.add(new JLabel("Student ID:")); applyPanel.add(txtApplyStudentId);
        applyPanel.add(new JLabel("Job ID:")); applyPanel.add(txtApplyJobId);
        JButton btnSubmitApply = new JButton("Submit Application");
        applyPanel.add(new JLabel()); applyPanel.add(btnSubmitApply);
        taInputPanel.add(applyPanel, "APPLY_JOB");

        // [输入面板 4] Status
        JPanel statusPanel = new JPanel(new GridLayout(2, 2, 10, 10));
        statusPanel.setBorder(BorderFactory.createTitledBorder(null, "Check Status", TitledBorder.DEFAULT_JUSTIFICATION, TitledBorder.DEFAULT_POSITION, TITLE_FONT));
        JTextField txtStatusStudentId = new JTextField();
        statusPanel.add(new JLabel("Student ID:")); statusPanel.add(txtStatusStudentId);
        JButton btnSubmitStatus = new JButton("Search");
        statusPanel.add(new JLabel()); statusPanel.add(btnSubmitStatus);
        taInputPanel.add(statusPanel, "CHECK_STATUS");

        // --- 底部数据展示区（文本与表格双重展示） ---
        JPanel displayPanel = new JPanel(new CardLayout());

        taDisplay = new JTextArea(10, 50);
        taDisplay.setEditable(false);
        taDisplay.setFont(new Font("Monospaced", Font.PLAIN, 14));
        displayPanel.add(new JScrollPane(taDisplay), "TEXT_VIEW");

        taTableModel = new DefaultTableModel();
        taTable = new JTable(taTableModel);
        taTable.setFont(NORMAL_FONT);
        taTable.setRowHeight(25);
        displayPanel.add(new JScrollPane(taTable), "TABLE_VIEW");

        // 组装中间区
        JPanel centerWrapper = new JPanel(new BorderLayout(10, 10));
        centerWrapper.add(taInputPanel, BorderLayout.NORTH);
        centerWrapper.add(displayPanel, BorderLayout.CENTER);
        taModule.add(centerWrapper, BorderLayout.CENTER);

        // ===================== TA事件绑定 =====================
        CardLayout displayCard = (CardLayout) displayPanel.getLayout();

        // 1. Profile
        btnCreateProfile.addActionListener(e -> {
            taInputCard.show(taInputPanel, "PROFILE");
            displayCard.show(displayPanel, "TEXT_VIEW");
            taDisplay.setText("Please fill in the form above to create or update your TA profile.");
        });

        btnSubmitProfile.addActionListener(e -> {
            String studentId = txtStudentId.getText().trim();
            if (Utils.isEmpty(studentId) || Utils.isEmpty(txtName.getText().trim())) {
                JOptionPane.showMessageDialog(this, "Student ID and Name are required!", "Error", JOptionPane.ERROR_MESSAGE);
                return;
            }
            String profile = String.format("{\n\"studentId\": \"%s\",\n\"name\": \"%s\",\n\"major\": \"%s\",\n\"phone\": \"%s\",\n\"cvPath\": \"%s\"\n}",
                    studentId, txtName.getText().trim(), txtMajor.getText().trim(), txtPhone.getText().trim(), txtCVPath.getText().trim());

            if (DataHandler.saveTAProfile(studentId, profile)) {
                JOptionPane.showMessageDialog(this, "Profile saved successfully!", "Success", JOptionPane.INFORMATION_MESSAGE);
                taDisplay.setText("Profile Updated:\n" + profile);
                txtStudentId.setText(""); txtName.setText(""); txtMajor.setText(""); txtPhone.setText(""); txtCVPath.setText("");
                taInputCard.show(taInputPanel, "EMPTY");
            }
        });

        // 2. Upload CV (已修复：添加了事件监听与校验逻辑)
        btnUploadCV.addActionListener(e -> {
            taInputCard.show(taInputPanel, "CV_UPLOAD");
            displayCard.show(displayPanel, "TEXT_VIEW");
            taDisplay.setText("=== Upload CV ===\nPlease enter the path of your CV file (txt/csv, ≤10MB).");
        });

        btnSubmitCV.addActionListener(e -> {
            String cvPath = txtCVUploadPath.getText().trim();
            if (Utils.isEmpty(cvPath)) {
                JOptionPane.showMessageDialog(this, "CV Path cannot be empty!", "Error", JOptionPane.ERROR_MESSAGE);
                return;
            }
            if (!Utils.validateCVFormat(cvPath)) {
                JOptionPane.showMessageDialog(this, "Only .txt and .csv files are allowed!", "Error", JOptionPane.ERROR_MESSAGE);
                return;
            }
            if (!Utils.validateCVSize(cvPath)) {
                JOptionPane.showMessageDialog(this, "File size exceeds 10MB!", "Error", JOptionPane.ERROR_MESSAGE);
                return;
            }
            JOptionPane.showMessageDialog(this, "CV uploaded and validated!", "Success", JOptionPane.INFORMATION_MESSAGE);
            taDisplay.setText("CV Upload Success:\nPath: " + cvPath + "\nFormat: Valid\nSize: Valid");
            txtCVUploadPath.setText("");
            taInputCard.show(taInputPanel, "EMPTY");
        });

        // 3. View Jobs
        btnViewJobs.addActionListener(e -> {
            taInputCard.show(taInputPanel, "EMPTY");
            displayCard.show(displayPanel, "TABLE_VIEW");
            List<String> jobs = DataHandler.loadAllJobs();
            updateTableData(taTableModel, jobs);
        });

        // 4. Apply Job
        btnApplyJob.addActionListener(e -> {
            taInputCard.show(taInputPanel, "APPLY_JOB");
            displayCard.show(displayPanel, "TEXT_VIEW");
            taDisplay.setText("Please enter your Student ID and the Job ID to apply.");
        });

        btnSubmitApply.addActionListener(e -> {
            String studentId = txtApplyStudentId.getText().trim();
            String jobId = txtApplyJobId.getText().trim();
            Map<String, String> profile = DataHandler.loadTAProfile(studentId);
            if (profile == null) {
                JOptionPane.showMessageDialog(this, "Profile not found! Create it first.", "Error", JOptionPane.ERROR_MESSAGE);
                return;
            }
            String application = String.join(",", jobId, studentId, profile.get("name"), profile.get("major"), profile.get("phone"), profile.get("cvPath"), Utils.getCurrentTime(), "Pending");
            if (DataHandler.submitApplication(application)) {
                JOptionPane.showMessageDialog(this, "Application submitted!", "Success", JOptionPane.INFORMATION_MESSAGE);
                taDisplay.setText("Application Submitted:\n" + application);
                txtApplyStudentId.setText(""); txtApplyJobId.setText("");
                taInputCard.show(taInputPanel, "EMPTY");
            }
        });

        // 5. Check Status
        btnCheckStatus.addActionListener(e -> {
            taInputCard.show(taInputPanel, "CHECK_STATUS");
            displayCard.show(displayPanel, "TABLE_VIEW");
            taTableModel.setRowCount(0); // 初始化时清空表格
            taTableModel.setColumnCount(0);
        });

        btnSubmitStatus.addActionListener(e -> {
            String studentId = txtStatusStudentId.getText().trim();
            if(Utils.isEmpty(studentId)){
                JOptionPane.showMessageDialog(this, "Student ID cannot be empty!", "Error", JOptionPane.ERROR_MESSAGE);
                return;
            }
            List<String> applications = DataHandler.loadAllApplications();
            // 在 application_list.csv 中，StudentID 在第1列 (索引为1)
            updateTableDataWithFilter(taTableModel, applications, 1, studentId);
        });

        return taModule;
    }

    // ===================== MO模块 (完整实现) =====================
    private JPanel createMOModule() {
        JPanel moModule = new JPanel(new BorderLayout(15, 15));

        // 顶部：MO功能按钮区
        JPanel moBtnPanel = new JPanel(new GridLayout(1, 3, 10, 10));
        JButton btnPublishJob = new JButton("1. Publish New Job");
        JButton btnViewAllJobs = new JButton("2. View All Published Jobs");
