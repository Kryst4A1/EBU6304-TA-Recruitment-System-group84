                JOptionPane.showMessageDialog(this, "Job ID cannot be empty!", "Error", JOptionPane.ERROR_MESSAGE);
                return;
            }
            List<String> applications = DataHandler.loadAllApplications();
            // 在 application_list.csv 中，JobID 在第0列 (索引为0)
            updateTableDataWithFilter(moTableModel, applications, 0, jobId);
        });

        return moModule;
    }

    // ===================== 核心通用方法：解析CSV至表格 =====================
    private void updateTableData(DefaultTableModel model, List<String> csvLines) {
        model.setRowCount(0); // 清空旧数据
        model.setColumnCount(0);
        if (csvLines == null || csvLines.isEmpty()) return;

        // 设置表头
        String[] headers = csvLines.get(0).split(",");
        model.setColumnIdentifiers(headers);

        // 填入数据
        for (int i = 1; i < csvLines.size(); i++) {
            model.addRow(csvLines.get(i).split(","));
        }
    }

    private void updateTableDataWithFilter(DefaultTableModel model, List<String> csvLines, int filterColIndex, String filterValue) {
        model.setRowCount(0);
        model.setColumnCount(0);
        if (csvLines == null || csvLines.isEmpty()) return;

        String[] headers = csvLines.get(0).split(",");
        model.setColumnIdentifiers(headers);

        for (int i = 1; i < csvLines.size(); i++) {
            String[] row = csvLines.get(i).split(",");
            if (row.length > filterColIndex && row[filterColIndex].equals(filterValue)) {
                model.addRow(row);
            }
        }

        if (model.getRowCount() == 0) {
            JOptionPane.showMessageDialog(this, "No records found for: " + filterValue, "Info", JOptionPane.INFORMATION_MESSAGE);
        }
    }

