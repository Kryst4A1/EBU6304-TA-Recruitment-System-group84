        // 1. Publish Job
        btnPublishJob.addActionListener(e -> {
            moInputCard.show(moInputPanel, "PUBLISH_JOB");
            displayCard.show(displayPanel, "TEXT_VIEW");
            moDisplay.setText("Please fill in the job information and submit.\nJob ID will be generated automatically.");
