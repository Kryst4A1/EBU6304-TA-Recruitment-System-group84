        filterPanel.setBorder(BorderFactory.createTitledBorder(null, "Filter Applicants", TitledBorder.DEFAULT_JUSTIFICATION, TitledBorder.DEFAULT_POSITION, TITLE_FONT));
        JTextField txtFilterJobId = new JTextField();
        filterPanel.add(new JLabel("Job ID:")); filterPanel.add(txtFilterJobId);
        JButton btnSubmitFilter = new JButton("Filter");
        filterPanel.add(new JLabel()); filterPanel.add(btnSubmitFilter);
        moInputPanel.add(filterPanel, "FILTER_APPLICANTS");

        // 底部显示区
        JPanel displayPanel = new JPanel(new CardLayout());

