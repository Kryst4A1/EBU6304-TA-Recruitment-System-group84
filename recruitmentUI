import javax.swing.*;
import java.awt.*;

public class RecruitmentUI extends JFrame {
    private CardLayout cardLayout;
    private JPanel mainPanel;

    // Main Panel
    private JPanel panelMain;
    private JButton btnTA, btnMO, btnAdmin, btnExit;

    // TA Panel
    private JPanel panelTA;
    private JButton btnCreateProfile, btnUploadCV, btnBackTA;

    // MO Panel
    private JPanel panelMO;
    private JButton btnPublishJob, btnBackMO;

    public RecruitmentUI() {
        initSystem();
        initFrame();
        initPanels();
        addListeners();
    }

    // Initialize system folder
    private void initSystem() {
        Utils.initSystem();
    }

    // Main window setup
    private void initFrame() {
        setTitle("BUPT International College TA Recruitment System");
        setSize(600, 500);
        setDefaultCloseOperation(EXIT_ON_CLOSE);
        setLocationRelativeTo(null);
        cardLayout = new CardLayout();
        mainPanel = new JPanel(cardLayout);
        add(mainPanel);
    }

    // Initialize all UI panels
    private void initPanels() {
        // Main Panel
        panelMain = new JPanel();
        panelMain.setLayout(new GridLayout(5, 1, 20, 20));
        panelMain.setBorder(BorderFactory.createEmptyBorder(50, 100, 50, 100));
        btnTA = new JButton("1. TA (Applicant)");
        btnMO = new JButton("2. MO (Module Organizer)");
        btnAdmin = new JButton("3. Admin (Not Available)");
        btnExit = new JButton("4. Exit System");
        panelMain.add(btnTA);
        panelMain.add(btnMO);
        panelMain.add(btnAdmin);
        panelMain.add(btnExit);

        // TA Panel
        panelTA = new JPanel();
        panelTA.setLayout(new GridLayout(4, 1, 20, 20));
        panelTA.setBorder(BorderFactory.createEmptyBorder(50, 100, 50, 100));
        btnCreateProfile = new JButton("Create Personal Profile");
        btnUploadCV = new JButton("Upload CV File");
        btnBackTA = new JButton("Back to Main");
        panelTA.add(btnCreateProfile);
        panelTA.add(btnUploadCV);
        panelTA.add(btnBackTA);

        // MO Panel
        panelMO = new JPanel();
        panelMO.setLayout(new GridLayout(3, 1, 20, 20));
        panelMO.setBorder(BorderFactory.createEmptyBorder(50, 100, 50, 100));
        btnPublishJob = new JButton("Publish TA Position");
        btnBackMO = new JButton("Back to Main");
        panelMO.add(btnPublishJob);
        panelMO.add(btnBackMO);

        // Add panels to CardLayout
        mainPanel.add(panelMain, "main");
        mainPanel.add(panelTA, "ta");
        mainPanel.add(panelMO, "mo");
    }

    // Button actions
    private void addListeners() {
        // Main menu
        btnTA.addActionListener(e -> cardLayout.show(mainPanel, "ta"));
        btnMO.addActionListener(e -> cardLayout.show(mainPanel, "mo"));
        btnAdmin.addActionListener(e -> JOptionPane.showMessageDialog(this, "Admin module is under development."));
        btnExit.addActionListener(e -> System.exit(0));

        // Back buttons
        btnBackTA.addActionListener(e -> cardLayout.show(mainPanel, "main"));
        btnBackMO.addActionListener(e -> cardLayout.show(mainPanel, "main"));

        // TA functions
        btnCreateProfile.addActionListener(e -> openCreateProfileDialog());
        btnUploadCV.addActionListener(e -> openUploadCVDialog());

        // MO functions
        btnPublishJob.addActionListener(e -> openPublishJobDialog());
    }

    // Dialog: Create TA Profile
    private void openCreateProfileDialog() {
        JTextField sid = new JTextField();
        JTextField name = new JTextField();
        JTextField major = new JTextField();
        JTextField phone = new JTextField();

        Object[] form = {
                "Student ID:", sid,
                "Full Name:", name,
                "Major:", major,
                "Phone Number:", phone
        };

        int result = JOptionPane.showConfirmDialog(this, form, "Create TA Profile", JOptionPane.OK_CANCEL_OPTION);
        if (result == JOptionPane.OK_OPTION) {
            java.util.Map<String, String> profile = new java.util.HashMap<>();
            profile.put("studentId", sid.getText());
            profile.put("name", name.getText());
            profile.put("major", major.getText());
            profile.put("phone", phone.getText());
            profile.put("cvPath", "Not Uploaded");
            profile.put("createTime", java.util.Calendar.getInstance().getTime().toString());

            DataHandler.saveTAProfile(profile);
            JOptionPane.showMessageDialog(this, "Profile created successfully!");
        }
    }

    // Dialog: Upload CV
    private void openUploadCVDialog() {
        JTextField sid = new JTextField();
        JTextField path = new JTextField();

        Object[] form = {
                "Bind to Student ID:", sid,
                "CV File Path (TXT/CSV):", path
        };

        int res = JOptionPane.showConfirmDialog(this, form, "Upload CV", JOptionPane.OK_CANCEL_OPTION);
        if (res == JOptionPane.OK_OPTION) {
            String studentId = sid.getText();
            String cvPath = path.getText();

            if (!Utils.checkFileFormat(cvPath)) {
                JOptionPane.showMessageDialog(this, "Only TXT/CSV files are supported.");
                return;
            }
            if (!Utils.checkFileSize(cvPath)) {
                JOptionPane.showMessageDialog(this, "File invalid or exceeds 10MB.");
                return;
            }
            JOptionPane.showMessageDialog(this, "CV uploaded successfully!\nBound to Student ID: " + studentId);
        }
    }

    // Dialog: Publish Job
    private void openPublishJobDialog() {
        JTextField jobName = new JTextField();
        JTextField jobReq = new JTextField();
        JTextField num = new JTextField();
        JTextField deadline = new JTextField();
        JTextField publisher = new JTextField();

        Object[] form = {
                "Position Title:", jobName,
                "Job Requirements:", jobReq,
                "Number of Openings:", num,
                "Deadline (yyyy-MM-dd):", deadline,
                "Publisher Name:", publisher
        };

        int res = JOptionPane.showConfirmDialog(this, form, "Publish TA Position", JOptionPane.OK_CANCEL_OPTION);
        if (res == JOptionPane.OK_OPTION) {
            try {
                String jobId = "J" + (int) (Math.random() * 1000 + 1000);
                String info = String.join(",",
                        jobId,
                        jobName.getText(),
                        jobReq.getText(),
                        num.getText(),
                        deadline.getText(),
                        publisher.getText()
                );
                DataHandler.publishJob(info);
                JOptionPane.showMessageDialog(this, "Position published successfully!");
            } catch (Exception ex) {
                JOptionPane.showMessageDialog(this, "Input format error.");
            }
        }
    }

    // Run UI
    public static void main(String[] args) {
        SwingUtilities.invokeLater(() -> {
            new RecruitmentUI().setVisible(true);
        });
    }
}
