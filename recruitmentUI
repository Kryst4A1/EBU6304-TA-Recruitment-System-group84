        JButton[] buttons = {btnPublishJob, btnViewAllJobs, btnFilterApplicants};
        for (JButton btn : buttons) {
            btn.setFont(NORMAL_FONT);
            moBtnPanel.add(btn);
        }
        moModule.add(moBtnPanel, BorderLayout.NORTH);

        // 中间：动态输入区
        CardLayout moInputCard = new CardLayout();
        JPanel moInputPanel = new JPanel(moInputCard);
        moInputPanel.add(new JPanel(), "EMPTY");

        // [输入面板 1] Publish New Job
        JPanel publishPanel = new JPanel(new GridLayout(5, 2, 10, 10));
