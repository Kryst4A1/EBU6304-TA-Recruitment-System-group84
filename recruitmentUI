        publishPanel.add(new JLabel("Position:")); publishPanel.add(txtPosition);
        publishPanel.add(new JLabel("Weekly Hours:")); publishPanel.add(txtHours);
        publishPanel.add(new JLabel("Requirements:")); publishPanel.add(txtRequirements);
        JButton btnSubmitPublish = new JButton("Publish Job");
        publishPanel.add(new JLabel()); publishPanel.add(btnSubmitPublish);
        moInputPanel.add(publishPanel, "PUBLISH_JOB");

